# ==========================
# shoko backend configuration
# ==========================
SHOKO_ENV=development
SHOKO_HOST=0.0.0.0
SHOKO_PORT=8000

# Comma-separated list of allowed CORS origins (the web dashboard).
SHOKO_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Seed the in-memory store with demo data on startup.
SHOKO_SEED_ON_STARTUP=true

# ==========================
# Protocol economics
# ==========================
# Fraction of stake slashed on a proven false claim.
SHOKO_SLASH_PCT=0.10
# Share of the slashed stake paid to a successful challenger.
SHOKO_CHALLENGER_REWARD_PCT=0.50
# Reputation penalties / rewards.
SHOKO_REP_PENALTY=15.0
SHOKO_FAILED_CHALLENGE_PENALTY=20.0
SHOKO_CHALLENGER_REP_REWARD=5.0
SHOKO_VERIFIED_REP_REWARD=2.0
SHOKO_BAD_CHALLENGE_PENALTY=5.0

# ==========================
# Consensus
# ==========================
# Fraction of providers that must agree for consensus to be reached.
SHOKO_CONSENSUS_QUORUM=0.5
