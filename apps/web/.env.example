# Base URL of the shoko FastAPI backend (no trailing slash).
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Cardano blockchain layer (src/blockchain) ──────────────────────────────
NEXT_PUBLIC_CARDANO_NETWORK=Preprod
NEXT_PUBLIC_BLOCKFROST_PROJECT_ID=
NEXT_PUBLIC_BLOCKFROST_URL=https://cardano-preprod.blockfrost.io/api/v0
NEXT_PUBLIC_KOIOS_URL=https://preprod.koios.rest/api/v1
# Compiled validator from `aiken build` (plutus.json → compiledCode) + address:
NEXT_PUBLIC_SHOKO_SCRIPT_CBOR=
NEXT_PUBLIC_SHOKO_SCRIPT_ADDRESS=
